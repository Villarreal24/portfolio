---
import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About | Angel Villarreal" description="About Luis A Villarreal">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. Read below to learn more about myself and my professional career."
			>
			<div class="flex justify-center">
				<img
					width="500"
					height="auto"
					src="/assets/profile.jpeg"
					alt="Angel Villarreal"
				/>
			</div>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						I’m a full-stack developer with several years (7+) of experience building modern web applications, 
						scalable backend architectures, and intelligent AI-powered features. I work with technologies 
						like Next.js, React, NestJS, TypeScript, Node.js, PostgreSQL, MongoDB, AWS, and GCP, 
						always with a focus on clean architecture and long term scalability.
					</p>
					<br>
					<p>
						In addition to full-stack and cloud development, I’ve been deeply involved in building AI-driven 
						products: LLM integrations, structured conversational workflows, prompt engineering systems, 
						automation pipelines, and agent-based architectures. I’ve designed and implemented chat interfaces, 
						data-capture flows, and backend services that connect user data with AI models to deliver real, 
						useful outcomes.
					</p>
					<br>
					<p>
						I also have hands-on experience in mobile development, contributing to cross-platform apps 
						and applying the same principles of performance, clarity, and maintainability that guide 
						my web work.
					</p>
					<br>
					<p>
						Across startups, agencies, and international teams, I’ve led projects end-to-end—translating 
						ideas into production platforms, collaborating closely with designers and engineers, and 
						delivering user experiences that are fast, intuitive, and reliable. Whether working independently 
						or as part of a team, I care about technical quality, thoughtful engineering, and building 
						software that genuinely improves products and the lives of the people who use them.
					</p>
					<br>
					<p>
						I’m continually exploring new tools and approaches, especially in AI and workflow automation and 
						I’m excited to keep creating meaningful, future-ready technology.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<div class="education-content">
						<p>Software Engienner</p>
						<div>
							<p>Universidad Estatal de Sonora (UES)</p>
							<p class="year">2015 - 2019</p>
						</div>
					</div>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content skills">
					<p>- Creative solutions</p>
					<p>- Web developer</p>
					<p>- Mobile developer</p>
					<p>- Team player</p>
					<p>- Design Knowledge</p>
					<p>- Communications skills</p>
					<p>- Infrastructure analysis</p>
					<p>- Autodidact</p>
					<p>- Accountability</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	.skills {
		display: grid;
		gap: 1rem; /* Espacio entre los elementos */
	}

	/* 1 columna por defecto (móvil) */
	.skills {
		grid-template-columns: repeat(1, 1fr);
	}

	/* 2 columnas en tablet (por ejemplo, pantallas de 600px en adelante) */
	@media (min-width: 600px) {
		.skills {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* 3 columnas en desktop (por ejemplo, pantallas de 1024px en adelante) */
	@media (min-width: 1024px) {
		.skills {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.education-content {
		display: flex;
		justify-content: space-between;
	}

	.year {
		font-size: smaller;
		text-align: right;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
